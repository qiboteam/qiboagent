{
  "data_dir": "./qiboKnow",                                    
  "persist_dir": "./chroma_qiboKnow",                          
  "rebuild": true,                                            
  "embedding_model": { 
    "type": "huggingface",                                     
    "model_name": "sentence-transformers/all-MiniLM-L6-v2"     
  },
  "llm": {
    "provider": "ollama",                                      
    "model_name": "llama3.2:1b",                               
    "base_url": "http://localhost:11434",                  
    "api_key": "your api_key",                                 
    "reasoning": false                                         
  },
  "workflow": {                                                
    "start_from_phase": 5,                                     
    "skip_cleanup": true                                       
  },
  "retriever": { 
    "search_type": "mmr",                                      
    "search_k": 6,                                             
    "fetch_k": 24,
    "mmr_lambda": 0.5
  },
  "questions_file": "./settings_json/questions_2.json",        
  "golden_file": "./settings_json/golden_answers_2.json",      
  "py_file_docstring" : "result_visualization.py"              
}
